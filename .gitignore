# --- WordPress Core (not tracked) ---
wp-admin/
wp-includes/
wp-*.php
xmlrpc.php
license.txt
readme.html
index.php

# --- WordPress Config (sensitive) ---
wp-config.php
wp-config-production.php
wp-config-sample.php

# --- wp-content root ---
wp-content/index.php
wp-content/uploads/
wp-content/upgrade/
wp-content/cache/
wp-content/backup*/
