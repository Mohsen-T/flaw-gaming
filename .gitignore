wp-content/plugins/*
!wp-content/plugins/flaw-gaming-core/

# --- Third-party themes ---
wp-content/themes/*
!wp-content/themes/flaw-gaming/

# --- Must-use plugins ---
wp-content/mu-plugins/

# --- Languages ---
wp-content/languages/

